# Copie ce fichier en .env.local et remplis les valeurs.
# cp .env.example .env.local

# --- Supabase (obligatoire) ---
# Settings → API dans le dashboard du projet
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Accès au groupe (obligatoire) ---
# Le mot de passe partagé qui garde l'entrée de l'app
NEXT_PUBLIC_GROUP_PASSWORD=

# --- Dates du challenge (optionnel) ---
# Défaut : 2026-07-13 → 2026-08-31 (voir lib/challenge.ts).
# À définir seulement pour une nouvelle instance/bande. Format AAAA-MM-JJ.
# Doivent être IDENTIQUES aux dates figées dans le SQL (voir supabase/README-nouvelle-instance.md).
# NEXT_PUBLIC_CHALLENGE_START=2026-07-13
# NEXT_PUBLIC_CHALLENGE_END=2026-08-31

# --- Notifications push (Phase 2) ---
# Génère la paire : npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# --- Crons (Phase 2) ---
# Secret partagé entre Vercel/GitHub Actions et les routes /api/cron/*
# Génère-le : openssl rand -hex 24
CRON_SECRET=

# --- Dev only (optionnel) ---
# Simule une date pour tester (ex. 2026-08-15). Aussi via ?date=... dans l'URL.
# NEXT_PUBLIC_SIM_DATE=
